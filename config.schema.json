{
  "pluginAlias": "HomebridgeCreateCeilingFan",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "required": true,
        "default": "Create Ceiling Fan"
      },
      "devices": {
        "type": "array",
        "title": "Fans",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "title": "ID",
              "description": "Tuya fan ID",
              "required": true
            },
            "key": {
              "type": "string",
              "title": "Key",
              "description": "Tuya fan key",
              "required": true
            },
            "name": {
              "type": "string",
              "title": "Fan Name",
              "description": "Name of the fan",
              "required": true
            },
            "beep": {
              "type": "boolean",
              "title": "Beep on command (v2 only)",
              "description": "Enable or disable the audible beep the fan emits on each command. Leave unset to not touch the device (recommended for v1 models which do not expose this Tuya DP). Applied once per Tuya reconnect.",
              "required": false
            },
            "toggles": {
              "type": "boolean",
              "title": "Expose stateless button tiles",
              "description": "Adds two Stateless Programmable Switch tiles that render as 'Button' category tiles in Apple Home. Default: on. Note: Apple Home cannot tap these nor target them as automation actions — they are placeholders.",
              "default": true,
              "required": false
            }
          }
        }
      }
    }
  }
}
